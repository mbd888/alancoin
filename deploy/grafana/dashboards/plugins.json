  "panels": [
    {
      "title": "Event Bus — Publish / Consume Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(alancoin_eventbus_published_total[1m])",
          "legendFormat": "Published/s"
        },
        {
          "expr": "rate(alancoin_eventbus_consumed_total[1m])",
          "legendFormat": "Consumed/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "Event Bus — Pending + Dropped + DLQ",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "alancoin_eventbus_pending",
          "legendFormat": "Pending"
        },
        {
          "expr": "rate(alancoin_eventbus_dropped_total[5m])",
          "legendFormat": "Dropped/5m"
        },
        {
          "expr": "alancoin_eventbus_dead_lettered_total",
          "legendFormat": "Dead-Lettered (total)"
        }
      ]
    },
    {
      "title": "KYA Certificates",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
